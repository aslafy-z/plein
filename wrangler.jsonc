{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "plein",
  "compatibility_date": "2026-07-13",
  "routes": [
    {
      "pattern": "plein.zadkiel.fr",
      "custom_domain": true
    }
  ],
  "workers_dev": false,
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
