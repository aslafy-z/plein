{
  "name": "plein",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "npm run build && wrangler dev",
    "typecheck": "tsc -b --noEmit",
    "e2e": "playwright test",
    "verify:live": "node scripts/live-providers.mjs",
    "check:ev-prices": "node scripts/check-ev-prices.mjs",
    "build:brands": "node scripts/build-brand-index.mjs",
    "build:icons": "node scripts/build-brand-icons.mjs",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.3",
    "vite": "^8.1.4",
    "wrangler": "^4.110.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
